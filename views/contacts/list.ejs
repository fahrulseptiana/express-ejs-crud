<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Manager</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b" role="navigation" aria-label="Main navigation">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold text-gray-800">Contact Manager</a>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto px-4 py-6">
    <% if (message) { %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
        <%= message %>
      </div>
    <% } %>

    <div class="bg-white rounded-lg shadow">
      <div class="p-4 border-b flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
        <a href="/contacts/export" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-center sm:text-left mr-2">Export JSON</a>
        <a href="/contacts/create" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-center sm:text-left focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">Add Contact</a>
        
        <form method="GET" role="search" class="flex flex-col sm:flex-row gap-2 items-stretch sm:items-center">
          <label for="search" class="sr-only">Search contacts</label>
          <input type="text" id="search" name="search" value="<%= query.search || '' %>" placeholder="Search by name..." 
                 class="border rounded px-3 py-2 w-full sm:w-40 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <label for="sort" class="sr-only">Sort by</label>
          <select id="sort" name="sort" class="border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="name" <%= query.sort === 'name' ? 'selected' : '' %>>Name</option>
            <option value="created_at" <%= query.sort === 'created_at' ? 'selected' : '' %>>Date</option>
          </select>
          <label for="order" class="sr-only">Sort order</label>
          <select id="order" name="order" class="border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="asc" <%= query.order === 'asc' ? 'selected' : '' %>>ASC</option>
            <option value="desc" <%= query.order === 'desc' ? 'selected' : '' %>>DESC</option>
          </select>
          <button type="submit" class="bg-gray-200 px-3 py-2 rounded hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-500">Filter</button>
        </form>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <caption class="sr-only">Contact list</caption>
          <thead class="bg-gray-50 border-b">
            <tr>
              <th scope="col" class="px-4 py-3 text-left text-sm font-medium text-gray-600">Photo</th>
              <th scope="col" class="px-4 py-3 text-left text-sm font-medium text-gray-600">Name</th>
              <th scope="col" class="px-4 py-3 text-left text-sm font-medium text-gray-600">Phone</th>
              <th scope="col" class="px-4 py-3 text-left text-sm font-medium text-gray-600">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% if (contacts.length === 0) { %>
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-gray-500">No contacts found</td>
            </tr>
            <% } else { %>
            <% contacts.forEach(function(c) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <% if (c.photo_url) { %>
                  <img src="<%= c.photo_url %>" alt="Photo of <%= c.name %>" class="w-10 h-10 rounded-full object-cover">
                <% } else { %>
                  <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500" aria-hidden="true"><%= c.name.charAt(0).toUpperCase() %></div>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-800"><%= c.name %></td>
              <td class="px-4 py-3 text-gray-600"><%= c.phone %></td>
              <td class="px-4 py-3">
                <a href="/contacts/<%= c.id %>/edit" class="text-blue-600 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded">Edit<span class="sr-only"> <%= c.name %></span></a>
                <span class="text-gray-300 mx-2" aria-hidden="true">|</span>
                <button type="button" class="text-red-600 hover:underline focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 rounded" onclick="showDeleteModal('<%= c.id %>', '<%= c.name %>')">Delete<span class="sr-only"> <%= c.name %></span></button>
              </td>
            </tr>
            <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>

      <% if (pagination.totalPages > 1) { %>
      <nav class="p-4 border-t flex flex-col sm:flex-row justify-between items-center gap-2" aria-label="Pagination">
        <span class="text-gray-600 text-sm">Page <%= pagination.page %> of <%= pagination.totalPages %> (<%= pagination.total %> contacts)</span>
        <div class="flex gap-2">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %>&search=<%= query.search || '' %>&sort=<%= query.sort || 'name' %>&order=<%= query.order || 'asc' %>" class="px-3 py-1 border rounded hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500" aria-label="Previous page">Previous</a>
          <% } %>
          <% if (pagination.page < pagination.totalPages) { %>
            <a href="?page=<%= pagination.page + 1 %>&search=<%= query.search || '' %>&sort=<%= query.sort || 'name' %>&order=<%= query.order || 'asc' %>" class="px-3 py-1 border rounded hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500" aria-label="Next page">Next</a>
          <% } %>
        </div>
      </nav>
      <% } %>
    </div>
  </main>

  <!-- Custom Modal -->
  <div id="modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50" role="dialog" aria-modal="true" aria-labelledby="modal-title" aria-hidden="true">
    <div class="bg-white rounded-lg shadow-xl max-w-sm w-full mx-4 p-6" role="document">
      <h3 id="modal-title" class="text-lg font-bold text-gray-800 mb-2">Confirm Delete</h3>
      <p id="modal-message" class="text-gray-600 mb-6">Are you sure you want to delete this contact?</p>
      <div class="flex justify-end gap-3">
        <button onclick="closeModal()" class="px-4 py-2 border border-gray-300 rounded text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500" id="modal-cancel">Cancel</button>
        <button id="modal-confirm" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500">Delete</button>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
